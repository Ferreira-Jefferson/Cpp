case "$1" in
    "")             main_loop ;;
    start)          cmd_start ;;
    phase)          cmd_phase "$2" ;;
    exercise)       cmd_exercise "$2" "$3" ;;
    check)          cmd_check ;;
    hint)           cmd_hint ;;
    explain)        cmd_explain ;;
    progress)       cmd_progress ;;
    reset)          cmd_reset ;;
    help|--help|-h) cmd_help ;;
    *)              cmd_help ;;
esac
