#!/bin/sh
LEARN_ROOT="$(cd "$(dirname "$0")" && pwd)"
. "$LEARN_ROOT/lib/colors.sh"
. "$LEARN_ROOT/lib/progress.sh"
progress_init

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_phase_name() {
    case "$1" in
        1) printf 'Leitura & Glossário' ;;
        2) printf 'Complete os Blanks' ;;
        3) printf 'Caça ao Bug' ;;
        4) printf 'Escreva Partes' ;;
        5) printf 'Do Zero' ;;
        *) printf 'Fase %s' "$1" ;;
    esac
}

_section() {
    # $1 = arquivo, $2 = nome da seção
    awk "/^## $2/{found=1; next} found && /^## /{exit} found{print}" "$1"
}

_show_exercise() {
    PHASE=$(progress_get_phase)
    EX=$(progress_get_exercise)
    INSTR="$LEARN_ROOT/phases/phase-$PHASE/exercise-$EX/instructions.md"
    NAME=$(_phase_name "$PHASE")

    printf "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"
    printf "${BOLD}  Fase %s — %s${RESET}\n" "$PHASE" "$NAME"
    printf "${BOLD}  Exercício %s/3${RESET}\n" "$EX"
    printf "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"

    if [ ! -f "$INSTR" ]; then
        printf "${YELLOW}[~] Arquivo de instruções não encontrado: %s${RESET}\n" "$INSTR"
    else
        printf '\n'
        _section "$INSTR" "Objetivo"
        printf '\n'
        _section "$INSTR" "Tarefa"
        printf '\n'
    fi

    if [ "$LEARN_TUI" != "1" ]; then
        printf "  ${GREEN}./learn check${RESET}   → valida seu Makefile\n"
        printf "  ${YELLOW}./learn hint${RESET}    → próxima dica\n"
        printf "  ${BLUE}./learn explain${RESET} → gabarito (bloqueado até check passar)\n"
    fi
    printf '\n'
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_help() {
    printf "${BOLD}makefile-learn — Aprendizado de Makefile C++ (42 School)${RESET}\n\n"
    printf "  ./learn start               Começa pelo início (Fase 1, Exercício 1)\n"
    printf "  ./learn phase <N>           Vai para a fase N (1-5)\n"
    printf "  ./learn exercise <N> <M>    Vai para fase N, exercício M\n"
    printf "  ./learn check               Valida seu Makefile\n"
    printf "  ./learn hint                Próxima dica (máx. 3)\n"
    printf "  ./learn explain             Mostra gabarito comentado\n"
    printf "  ./learn progress            Exibe seu progresso\n"
    printf "  ./learn reset               Reinicia o progresso\n"
    printf '\n'
}

cmd_start() {
    progress_set_current 1 1
    _show_exercise
}

cmd_phase() {
    N="$1"
    case "$N" in
        [1-5]) ;;
        *) printf "${RED}[✗] Fase inválida. Use um número entre 1 e 5.${RESET}\n"; return 1 ;;
    esac
    progress_set_current "$N" 1
    _show_exercise
}

cmd_exercise() {
    N="$1"
    M="$2"
    case "$N" in
        [1-5]) ;;
        *) printf "${RED}[✗] Fase inválida. Use um número entre 1 e 5.${RESET}\n"; return 1 ;;
    esac
    case "$M" in
        [1-3]) ;;
        *) printf "${RED}[✗] Exercício inválido. Use um número entre 1 e 3.${RESET}\n"; return 1 ;;
    esac
    progress_set_current "$N" "$M"
    _show_exercise
}

cmd_check() {
    PHASE=$(progress_get_phase)
    EX=$(progress_get_exercise)
    EX_DIR="$LEARN_ROOT/phases/phase-$PHASE/exercise-$EX"
    export LEARN_ROOT LEARN_PHASE="$PHASE" LEARN_EXERCISE="$EX" LEARN_EX_DIR="$EX_DIR"
    sh "$LEARN_ROOT/lib/check.sh"
}

cmd_hint() {
    PHASE=$(progress_get_phase)
    EX=$(progress_get_exercise)
    USED=$(progress_get_hints "$PHASE" "$EX")
    if [ "$USED" -ge 3 ]; then
        printf "${YELLOW}[~] Sem mais dicas. Use ./learn explain para ver o gabarito.${RESET}\n"
        return
    fi
    NEXT=$((USED + 1))
    INSTR="$LEARN_ROOT/phases/phase-$PHASE/exercise-$EX/instructions.md"
    if [ ! -f "$INSTR" ]; then
        printf "${YELLOW}[~] Arquivo de instruções não encontrado.${RESET}\n"
        return
    fi
    DICA=$(awk "/^### Dica $NEXT/{found=1; next} found && /^### /{exit} found{print}" "$INSTR" | sed '/^$/d')
    printf "${YELLOW}[~] Dica %s/3: ${RESET}%s\n" "$NEXT" "$DICA"
    progress_inc_hint "$PHASE" "$EX"
}

cmd_explain() {
    PHASE=$(progress_get_phase)
    EX=$(progress_get_exercise)
    if ! progress_can_explain "$PHASE" "$EX"; then
        printf "${BLUE}[i] Complete o exercício primeiro (./learn check).${RESET}\n"
        return
    fi
    SOL_DIR="$LEARN_ROOT/phases/phase-$PHASE/exercise-$EX/.solution"
    printf "${BOLD}Gabarito — Fase $PHASE, Exercício $EX:${RESET}\n\n"
    if [ -f "$SOL_DIR/Makefile.sol" ]; then
        cat "$SOL_DIR/Makefile.sol"
    elif [ -f "$SOL_DIR/answers.txt" ]; then
        printf "${BOLD}Respostas corretas:${RESET}\n"
        cat "$SOL_DIR/answers.txt"
    else
        printf "${YELLOW}[~] Gabarito não encontrado.${RESET}\n"
    fi
}

cmd_progress() {
    CUR_PHASE=$(progress_get_phase)
    CUR_EX=$(progress_get_exercise)

    printf "${BOLD}makefile-learn — Progresso${RESET}\n\n"

    i=1
    while [ "$i" -le 5 ]; do
        NAME=$(_phase_name "$i")
        # Count completed exercises in this phase
        ARR=$(_read_completed_array "$(_progress_file)" "$i")
        if [ -z "$ARR" ]; then
            COUNT=0
        else
            COUNT=$(printf '%s' "$ARR" | tr ',' '\n' | grep -c '[0-9]')
        fi

        # Build 20-char bar
        FILLED=$(( COUNT * 20 / 3 ))
        EMPTY=$(( 20 - FILLED ))
        BAR=''
        j=0
        while [ "$j" -lt "$FILLED" ]; do
            BAR="${BAR}█"
            j=$((j + 1))
        done
        j=0
        while [ "$j" -lt "$EMPTY" ]; do
            BAR="${BAR}░"
            j=$((j + 1))
        done

        if [ "$COUNT" -eq 3 ]; then
            STATUS="${GREEN}COMPLETO${RESET}"
            printf "  Fase %s  %-30s [%s] %s/3  %b\n" "$i" "$NAME" "$BAR" "$COUNT" "$STATUS"
        else
            printf "  Fase %s  %-30s [%s] %s/3\n" "$i" "$NAME" "$BAR" "$COUNT"
        fi

        i=$((i + 1))
    done

    printf '\n  Atual: Fase %s, Exercício %s\n\n' "$CUR_PHASE" "$CUR_EX"
}

cmd_reset() {
    printf 'Tem certeza que quer reiniciar o progresso? [s/N] '
    read CONFIRM
    case "$CONFIRM" in
        s|S)
            cat > "$(_progress_file)" <<'EOF'
{
  "current_phase": 1,
  "current_exercise": 1,
  "completed": {
    "1": [],
    "2": [],
    "3": [],
    "4": [],
    "5": []
  },
  "hints_used": {},
  "explain_unlocked": {}
}
EOF
            printf "${GREEN}[✓] Progresso reiniciado.${RESET}\n"
            ;;
        *)
            printf 'Cancelado.\n'
            ;;
    esac
}

# ---------------------------------------------------------------------------
# TUI Functions
# ---------------------------------------------------------------------------

tui_header() {
    PHASE=$(progress_get_phase)
    EX=$(progress_get_exercise)
    NAME=$(_phase_name "$PHASE")

    printf "${BOLD}═══════════════════════════════════════════════════════${RESET}\n"
    printf "${BOLD}  makefile-learn  |  Fase %s — %s  |  Exercício %s/3${RESET}\n" "$PHASE" "$NAME" "$EX"

    BAR=""
    i=1
    while [ "$i" -le 5 ]; do
        COUNT=$(progress_count_done "$i")
        case "$COUNT" in
            3) SEG="${GREEN}[███]${RESET}" ;;
            2) SEG="${YELLOW}[██░]${RESET}" ;;
            1) SEG="${YELLOW}[█░░]${RESET}" ;;
            *) SEG="[░░░]" ;;
        esac
        if [ "$i" -lt 5 ]; then
            BAR="${BAR}${SEG} "
        else
            BAR="${BAR}${SEG}"
        fi
        i=$((i + 1))
    done
    printf "  %b   F1·F2·F3·F4·F5\n" "$BAR"
    printf "${BOLD}═══════════════════════════════════════════════════════${RESET}\n\n"
}

tui_menu() {
    PHASE=$(progress_get_phase)
    EX=$(progress_get_exercise)
    HINTS_USED=$(progress_get_hints "$PHASE" "$EX")
    HINTS_NEXT=$((HINTS_USED + 1))

    if progress_can_explain "$PHASE" "$EX"; then
        EXPLAIN_LABEL="Ver gabarito"
    else
        EXPLAIN_LABEL="${RED}Gabarito (bloqueado)${RESET}"
    fi

    if [ "$HINTS_USED" -ge 3 ]; then
        HINT_LABEL="${RED}Sem mais dicas${RESET}"
    else
        HINT_LABEL="Dica (${HINTS_NEXT}/3)"
    fi

    if [ "$PHASE" = "1" ]; then
        INSTR_TMP="$LEARN_ROOT/phases/phase-$PHASE/exercise-$EX/instructions.md"
        if grep -q '^## QuizComandos' "$INSTR_TMP" 2>/dev/null; then
            QUIZ_LABEL="Glossário & Quiz de Comandos"
        else
            QUIZ_LABEL="Responder quiz no terminal"
        fi
    else
        QUIZ_LABEL="${RED}Quiz inline (apenas Fase 1)${RESET}"
    fi

    printf "  [1] Ver exercício atual\n"
    printf "  [2] Verificar (check)\n"
    printf "  [3] %b\n" "$QUIZ_LABEL"
    printf "  [4] %b\n" "$HINT_LABEL"
    printf "  [5] %b\n" "$EXPLAIN_LABEL"
    printf "  [6] Progresso geral\n"
    printf "  [7] Navegar (fase/exercício)\n"
    printf "  [8] Reiniciar progresso\n"
    printf "  [0] Sair\n\n"
    printf "  Escolha: "
    read -r MENU_CHOICE
}

# ---------------------------------------------------------------------------
# Phase 1 — Glossary explorer (user types a command name, sees explanation)
# ---------------------------------------------------------------------------
tui_glossary_explore() {
    INSTR="$1"

    while true; do
        printf '\033[2J\033[H'
        tui_header

        printf "  ${BOLD}Explorar Comandos${RESET}\n\n"

        # List available entries from ## Glossário section
        printf "  Comandos disponíveis:\n"
        awk '/^## Glossário/{f=1; next} f && /^## /{exit} f && /^### /{gsub(/^### /,""); printf "    • %s\n", $0}' "$INSTR"

        printf "\n  Digite o nome de um comando para ver a explicação.\n"
        printf "  (Enter em branco para voltar)\n\n"
        printf "  Comando: "
        read -r USER_CMD

        # Trim whitespace/CR
        USER_CMD=$(printf '%s' "$USER_CMD" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

        [ -z "$USER_CMD" ] && return

        printf '\033[2J\033[H'
        tui_header

        # Lookup in glossary (exact match, case-sensitive)
        EXPLANATION=$(awk -v cmd="$USER_CMD" '
            /^## Glossário/{sec=1; next}
            sec && /^## /{exit}
            sec && /^### / {
                entry=substr($0, 5)
                in_entry=(entry == cmd)
                next
            }
            sec && in_entry { print }
        ' "$INSTR")

        if [ -n "$EXPLANATION" ]; then
            printf "  ${BOLD}${GREEN}%s${RESET}\n" "$USER_CMD"
            printf "  ────────────────────────────────────────\n"
            printf '%s\n' "$EXPLANATION" | while IFS= read -r LINE; do
                printf "  %s\n" "$LINE"
            done
        else
            printf "  ${RED}[✗] '%s' não encontrado no glossário.${RESET}\n" "$USER_CMD"
            printf "  Verifique a grafia exata (maiúsculas importam).\n"
        fi

        printf "\n  Pressione Enter para continuar..."
        read -r _PAUSE
    done
}

# ---------------------------------------------------------------------------
# Phase 1 — Command-name quiz (description shown, user types the command)
# ---------------------------------------------------------------------------
tui_command_quiz() {
    INSTR="$1"
    STUDENT="$2"

    TOTAL=$(awk '/^## QuizComandos/{f=1; next} f && /^## /{exit} f && /^### C[0-9]/{count++} END{print count+0}' "$INSTR")

    if [ -z "$TOTAL" ] || [ "$TOTAL" -eq 0 ]; then
        printf "\n  ${YELLOW}[~] Nenhuma questão de comandos encontrada.${RESET}\n"
        printf "\n  Pressione Enter para continuar..."
        read -r _PAUSE
        return
    fi

    if [ -f "$STUDENT" ]; then
        printf '\033[2J\033[H'
        tui_header
        printf "  Já existe um arquivo de respostas. Sobrescrever? [s/N] "
        read -r OVERWRITE
        case "$OVERWRITE" in
            s|S) ;;
            *)
                printf "  Mantendo respostas existentes.\n"
                printf "\n  Pressione Enter para continuar..."
                read -r _PAUSE
                return
                ;;
        esac
    fi

    > "$STUDENT"

    N=1
    while [ "$N" -le "$TOTAL" ]; do
        printf '\033[2J\033[H'
        tui_header
        printf "  ${BOLD}Quiz de Comandos — Pergunta %s/%s${RESET}\n\n" "$N" "$TOTAL"
        printf "  Leia a descrição e escreva o nome do comando que corresponde:\n\n"

        awk -v qnum="$N" '
            /^## QuizComandos/{sec=1; next}
            sec && /^## /{exit}
            sec && /^### C[0-9]/ {
                label=substr($0,5)
                gsub(/^C/, "", label)
                n=label+0
                in_q=(n==qnum)
                next
            }
            sec && in_q { print "  " $0 }
        ' "$INSTR"

        printf "\n"
        printf "  ${BLUE}(0 para voltar ao menu)${RESET}\n\n"
        VALID=""
        ABORT=0
        while [ -z "$VALID" ]; do
            printf "  Sua resposta: "
            read -r RAW_ANS
            ANS=$(printf '%s' "$RAW_ANS" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            if [ "$ANS" = "0" ]; then
                ABORT=1
                break
            elif [ -n "$ANS" ]; then
                VALID="$ANS"
            else
                printf "  ${RED}[✗] Digite o nome do comando.${RESET}\n"
            fi
        done

        [ "$ABORT" = "1" ] && return

        printf "c%s:%s\n" "$N" "$VALID" >> "$STUDENT"
        N=$((N + 1))
    done

    printf '\033[2J\033[H'
    tui_header
    printf "  ${GREEN}[✓] %s respostas salvas.${RESET}\n" "$TOTAL"
    printf "  Use a opção [2] para checar suas respostas.\n"
    printf "\n  Pressione Enter para continuar..."
    read -r _PAUSE
}

# ---------------------------------------------------------------------------
# Phase 1 — Dispatcher: glossary+command quiz OR legacy multiple-choice
# ---------------------------------------------------------------------------
tui_quiz_interactive() {
    PHASE=$(progress_get_phase)
    EX=$(progress_get_exercise)

    if [ "$PHASE" != "1" ]; then
        printf "\n  ${YELLOW}[~] Quiz interativo disponível apenas na Fase 1.${RESET}\n"
        printf "\n  Pressione Enter para continuar..."
        read -r _PAUSE
        return
    fi

    INSTR="$LEARN_ROOT/phases/phase-$PHASE/exercise-$EX/instructions.md"
    STUDENT="$LEARN_ROOT/phases/phase-$PHASE/exercise-$EX/.student_answers.txt"

    if [ ! -f "$INSTR" ]; then
        printf "\n  ${RED}[✗] Arquivo de instruções não encontrado.${RESET}\n"
        printf "\n  Pressione Enter para continuar..."
        read -r _PAUSE
        return
    fi

    # New format: glossary + command-name quiz
    if grep -q '^## QuizComandos' "$INSTR" 2>/dev/null; then
        while true; do
            printf '\033[2J\033[H'
            tui_header
            printf "  ${BOLD}Fase 1 — Glossário & Quiz${RESET}\n\n"
            printf "  [1] Explorar comandos (aprenda o que cada um faz)\n"
            printf "  [2] Responder o quiz (escreva o nome do comando)\n"
            printf "  [0] Voltar\n\n"
            printf "  Escolha: "
            read -r P1_CHOICE
            case "$P1_CHOICE" in
                1) tui_glossary_explore "$INSTR" ;;
                2) tui_command_quiz "$INSTR" "$STUDENT" ; return ;;
                0) return ;;
                *) ;;
            esac
        done
    else
        # Legacy multiple-choice quiz
        TOTAL=$(awk '/^### Q[0-9]/{count++} END{print count}' "$INSTR")

        if [ -z "$TOTAL" ] || [ "$TOTAL" -eq 0 ]; then
            printf "\n  ${YELLOW}[~] Nenhuma questão encontrada.${RESET}\n"
            printf "\n  Pressione Enter para continuar..."
            read -r _PAUSE
            return
        fi

        if [ -f "$STUDENT" ]; then
            printf "\n  Já existe um arquivo de respostas. Sobrescrever? [s/N] "
            read -r OVERWRITE
            case "$OVERWRITE" in
                s|S) ;;
                *)
                    printf "  Mantendo respostas existentes.\n"
                    printf "\n  Pressione Enter para continuar..."
                    read -r _PAUSE
                    return
                    ;;
            esac
        fi

        > "$STUDENT"

        N=1
        while [ "$N" -le "$TOTAL" ]; do
            printf '\033[2J\033[H'
            tui_header
            printf "  ${BOLD}Questão %s/%s${RESET}\n\n" "$N" "$TOTAL"

            awk -v qnum="$N" '
                /^### Q/ {
                    qn = substr($0, 6)
                    if (qn == qnum) { in_q=1; next }
                    else if (in_q) { exit }
                }
                /^## / && in_q { exit }
                in_q { print "  " $0 }
            ' "$INSTR"

            printf "\n"
            VALID=""
            while [ -z "$VALID" ]; do
                printf "  Sua resposta (a/b/c/d): "
                read -r RAW_ANS
                ANS=$(printf '%s' "$RAW_ANS" | tr 'A-Z' 'a-z' | tr -d ' \r\n')
                case "$ANS" in
                    a|b|c|d) VALID="$ANS" ;;
                    *) printf "  ${RED}[✗] Digite apenas a, b, c ou d.${RESET}\n" ;;
                esac
            done

            printf "q%s:%s\n" "$N" "$VALID" >> "$STUDENT"
            N=$((N + 1))
        done

        printf '\033[2J\033[H'
        tui_header
        printf "  ${GREEN}[✓] %s respostas salvas.${RESET}\n" "$TOTAL"
        printf "  Use a opção [2] para checar suas respostas.\n"
        printf "\n  Pressione Enter para continuar..."
        read -r _PAUSE
    fi
}

tui_check_and_advance() {
    PHASE=$(progress_get_phase)
    EX=$(progress_get_exercise)

    if ! progress_is_done "$PHASE" "$EX"; then
        printf "\n  Pressione Enter para continuar..."
        read -r _PAUSE
        return
    fi

    NEXT_EX=$((EX + 1))
    if [ "$NEXT_EX" -le 3 ]; then
        printf "\n"
        printf "  ${GREEN}[✓] Exercício completo!${RESET} Avançar para Exercício %s? [S/n] " "$NEXT_EX"
        read -r ADVANCE
        case "$ADVANCE" in
            n|N) ;;
            *)
                progress_set_current "$PHASE" "$NEXT_EX"
                printf "  Avançando para Fase %s, Exercício %s.\n" "$PHASE" "$NEXT_EX"
                ;;
        esac
    else
        NEXT_PHASE=$((PHASE + 1))
        if [ "$NEXT_PHASE" -le 5 ]; then
            printf "\n"
            printf "  ${GREEN}[✓] Fase %s completa!${RESET} Avançar para Fase %s? [S/n] " "$PHASE" "$NEXT_PHASE"
            read -r ADVANCE
            case "$ADVANCE" in
                n|N) ;;
                *)
                    progress_set_current "$NEXT_PHASE" 1
                    printf "  Avançando para Fase %s, Exercício 1.\n" "$NEXT_PHASE"
                    ;;
            esac
        else
            printf "\n"
            printf "${BOLD}${GREEN}  ╔══════════════════════════════════════╗\n"
            printf "  ║  Parabéns! Curso 100%% concluído!     ║\n"
            printf "  ╚══════════════════════════════════════╝${RESET}\n"
        fi
    fi

    printf "\n  Pressione Enter para continuar..."
    read -r _PAUSE
}

tui_navigate() {
    printf "  Navegar para:\n"
    printf "  [1] Fase específica (início do exercício 1)\n"
    printf "  [2] Fase e exercício específicos\n"
    printf "  [0] Voltar\n\n"
    printf "  Escolha: "
    read -r NAV_CHOICE

    case "$NAV_CHOICE" in
        1)
            printf "  Fase (1-5): "
            read -r NAV_PHASE
            case "$NAV_PHASE" in
                [1-5])
                    progress_set_current "$NAV_PHASE" 1
                    printf "  ${GREEN}[✓] Navegado para Fase %s, Exercício 1.${RESET}\n" "$NAV_PHASE"
                    ;;
                *)
                    printf "  ${RED}[✗] Fase inválida. Use 1-5.${RESET}\n"
                    ;;
            esac
            ;;
        2)
            printf "  Fase (1-5): "
            read -r NAV_PHASE
            printf "  Exercício (1-3): "
            read -r NAV_EX
            case "$NAV_PHASE" in
                [1-5])
                    case "$NAV_EX" in
                        [1-3])
                            progress_set_current "$NAV_PHASE" "$NAV_EX"
                            printf "  ${GREEN}[✓] Navegado para Fase %s, Exercício %s.${RESET}\n" "$NAV_PHASE" "$NAV_EX"
                            ;;
                        *)
                            printf "  ${RED}[✗] Exercício inválido. Use 1-3.${RESET}\n"
                            ;;
                    esac
                    ;;
                *)
                    printf "  ${RED}[✗] Fase inválida. Use 1-5.${RESET}\n"
                    ;;
            esac
            ;;
        0|*)
            return
            ;;
    esac

    printf "\n  Pressione Enter para continuar..."
    read -r _PAUSE
}

main_loop() {
    if ! [ -t 0 ]; then
        printf "${YELLOW}[~] Modo interativo requer um terminal. Use ./learn <comando>.${RESET}\n"
        cmd_help
        return 1
    fi

    export LEARN_TUI=1

    while true; do
        printf '\033[2J\033[H'
        tui_header
        _show_exercise
        tui_menu

        case "$MENU_CHOICE" in
            1)
                printf "\n  Pressione Enter para continuar..."
                read -r _PAUSE
                ;;
            2)
                printf '\033[2J\033[H'
                tui_header
                cmd_check
                tui_check_and_advance
                ;;
            3)
                tui_quiz_interactive
                ;;
            4)
                printf '\033[2J\033[H'
                tui_header
                cmd_hint
                printf "\n  Pressione Enter para continuar..."
                read -r _PAUSE
                ;;
            5)
                printf '\033[2J\033[H'
                tui_header
                cmd_explain
                printf "\n  Pressione Enter para continuar..."
                read -r _PAUSE
                ;;
            6)
                printf '\033[2J\033[H'
                cmd_progress
                printf "\n  Pressione Enter para continuar..."
                read -r _PAUSE
                ;;
            7)
                printf '\033[2J\033[H'
                tui_header
                tui_navigate
                ;;
            8)
                printf '\033[2J\033[H'
                cmd_reset
                printf "\n  Pressione Enter para continuar..."
                read -r _PAUSE
                ;;
            0)
                printf "  Até logo!\n"
                unset LEARN_TUI
                exit 0
                ;;
            *)
                printf "  ${RED}[✗] Opção inválida. Digite um número de 0 a 8.${RESET}\n"
                printf "\n  Pressione Enter para continuar..."
                read -r _PAUSE
                ;;
        esac
    done
}

